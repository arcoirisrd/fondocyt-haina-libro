@mastersthesis{fernandezdepradaPlanAccionSocial2023,
  title = {Plan de Acci\'on Social Para La Gesti\'on Integral Del Riesgo de Desastres En El Municipio de Bajos de Haina, Rep\'ublica Dominicana. {{Fortaleciendo}} Las Capacidades Locales Para Transformar Territorios Vulnerables En Comunidades Resilientes},
  author = {{Fern{\'a}ndez de Prada}, Beatriz},
  year = 2023,
  journal = {Ingenieria\_2014},
  pages = {177},
  abstract = {El presente Trabajo de Fin de M\'aster constituye un ejercicio dual, acad\'emico y profesional, en el que se realiza un an\'alisis multinivel las capacidades locales para la Gesti\'on Integral del Riesgo de Desastres (GIRD) y una propuesta de l\'ineas estrat\'egicas de actuaci\'on en el municipio de Bajos de Haina, Republica Dominicana. La zona de intervenci\'on manifiesta una elevada exposici\'on a amenazas m\'ultiples, especialmente la inundaci\'on, que genera una multiplicidad de impactos que se distribuyen de forma desigual afectando de manera desproporcionada a la poblaci\'on de los barrios vulnerables. Partiendo de los principios de la investigaci\'on-acci\'on-participaci\'on, el trabajo persigue la generaci\'on de procesos de transformaci\'on participativa a trav\'es de la investigaci\'on aplicada, tratando de involucrar de manera efectiva a los actores locales clave en las distintas etapas del Plan. Con el fin de elaborar el diagn\'ostico de la problem\'atica se recurre a una metodolog\'ia mixta. En una primera parte la revisi\'on bibliogr\'afica y de documentos oficiales permite construir un marco te\'orico que gu\'ia el dise\~no metodol\'ogico posterior, que se adec\'ua a la naturaleza del actor y de la informaci\'on requerida. Se combina el uso de t\'ecnicas de investigaci\'on cualitativa, como la entrevista semiestructurada a puntos focales de actores clave, con la realizaci\'on de encuestas CAP ---Conocimientos, Actitudes y Pr\'acticas--- a una muestra acotada de la poblaci\'on en un ejercicio exploratorio de la percepci\'on social del riesgo. En \'ultimo t\'ermino se incluye una propuesta de ejes estrat\'egicos de actuaci\'on con objetivos y medidas prioritarias dirigidas a transformar territorios vulnerables a los desastres y al cambio clim\'atico, como el municipio de Haina, en territorios resilientes y adaptados al cambio clim\'atico.    ABSTRACT    This Master's thesis is a dual academic and professional exercise. Both, a multilevel analysis of local capacities for Integrated Disaster Risk Management (IDRM) and a proposal for strategic lines of action in the municipality of Bajos de Haina, Dominican Republic are carried out. The intervention area is highly exposed to multiple hazards, especially flooding, which brings about multiple impacts that are unevenly distributed, disproportionately affecting the population of vulnerable areas. Based on the principles of participatory action research, the work pursues the generation of participatory transformation processes through applied research, trying to involve key local actors in the different stages of the Plan. In order to elaborate the diagnosis of the problem, a mixed methodology is used. In the first part, a review of academic literature and official documents conducts the construction of a theoretical framework that guides the subsequent methodological design. The latter is adapted to the nature of the actor and the information required. The use of qualitative research techniques, such as semi-structured interviews, is combined with the implementation of KAP surveys ---Knowledge, Attitudes and Practices--- to a limited sample of the population to explore social perception of risk. Finally, a proposal for strategic lines of action is included with objectives and priority measures aimed at transforming territories vulnerable to disasters and climate change, such as the municipality of Haina, into resilient territories adapted to climate change.},
  school = {Agronomica},
  file = {C:\Users\Jorge Recio\Zotero\storage\TTZC4X8B\de Prada - PLAN DE ACCIÓN SOCIAL PARA LA GESTIÓN INTEGRAL DEL.pdf}
}

