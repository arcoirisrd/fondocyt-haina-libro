@misc{europeanculturalcentreitalyShapingCityVenice2021,
  title = {Shaping the City Venice 2021 \textbar{} Re-Imagining the City (Day 1 - Panel 1)},
  year = 2021,
  month = oct,
  urldate = {2024-08-19},
  abstract = {`Shaping the City: A Forum for Sustainable Cities and Communities' is a forum organized by the European Cultural Centre (ECC) in the context of its Venice Architecture Biennial Exhibition titled `Time Space Existence'. This second edition of the conference recognizes the significant role urban planning and design play in molding the interaction of people with their cities and their wellbeing. Through a series of presentations and panel discussions the forum confronts the fundamental topics shaping the cities of our world. The panel `Re-Imagining the City' explores the transformation of our cities as dynamic processes, looking at how the morphological dimension, engulfing both the architectural character and the urban environment, creates an image and an identity for the city. This theme draws attention to both the need to keep an identity and the urgency to create safer cities after natural and social disasters, focusing on how the relationship of the people and their physical space is shaped. Moderator: Allen Sayegh - Harvard University, Real Lab Speakers: - Stefano Andreani - REAL Lab, Harvard University - Apostolos Kyriazis and Nadia Mounajjed - Abu Dhabi University - Ulrich Gehmann - Ideal Spaces x National Pavilion of Italy Venice 2021 - Pia Fricker - Aalto University - Divina Abou Jaoude - Order of Architects and Engineers \_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_\_ The European Cultural Centre is a cultural organisation founded by the Dutch artist Rene Rietmeyer in 2002 aimed at heightening the awareness about the more philosophical themes in contemporary art and architecture. Follow us Instagram \textbar{} https://bit.ly/3eJeuB1 Facebook \textbar{} hhttps://bit.ly/3zjToCV  LinkedIn \textbar{} https://bit.ly/3Ht430Y  Newsletter \textbar{} https://mailchi.mp/9602b7ed48b4/tse Discover more Shaping The City \textbar{} https://linktr.ee/shapingthecityforum  Time Space Existence \textbar{} http://timespaceexistence.com/ ECC Italy \textbar{} https://ecc-italy.eu/ ECC Worldwide \textbar{} https://europeanculturalcentre.eu/ Instagram ECC \textbar{} https://bit.ly/3JC8usd  \#ShapingtheCityForum~\#STC2021~\#ShapingtheCity2021~\#ReimaginingtheCity~\#ECCitaly~\#EuropeanCulturalCentre},
  collaborator = {{European Cultural Centre Italy}}
}

@article{falconDesigualdadEstrategiasSupervivencia2019,
  title = {{Desigualdad y estrategias de supervivencia en la poblaci\'on femenina de haina, R. Dominicana.}},
  author = {Falc{\'o}n, Carmen Meneses},
  year = 2019,
  month = feb,
  journal = {iQual. Revista de G\'enero e Igualdad},
  number = {2},
  pages = {93--113},
  issn = {2603-851X},
  doi = {10.6018/iQual.342281},
  urldate = {2024-03-13},
  abstract = {This work delves into the causes of prostitution and trafficking for the purpose of sexual exploitation, from the analysis of the living conditions of poor women in the Dominican Republic, specifically in the Bajos de Haina. It is one of the Latin American countries with the largest presence of women in prostitution in Spain and Europe and among the victims of trafficking for the purpose of sexual exploitation. Through interviews with key informants and participant observation, qualitative information on the social circumstances of girls, adolescents and women was collected. Three characteristics that push women to migration and the exercise of prostitution can be highlighted: gender inequalities, with women in a hierarchical and subordinate position to men; very precocious motherhood, with poor bonding of the couple, which makes young girls assume the responsibilities of their children; gender violence, specifically violence by the intimate partner and violence towards the girls in the family unit, mainly incest. The absence of effective social resources that help women along with the lack of efficient policies that sensitize and raise awareness among the population about gender equity are some of the goals that must be met.},
  copyright = {Derechos de autor 2019 Servicio de Publicaciones Universidad de Murcia},
  langid = {spanish},
  keywords = {desigualdad,mujeres,prostitucion,violencia,vulnerabilidad},
  file = {C:\Users\Jorge Recio\Zotero\storage\KHUAKRR8\Falcón - 2019 - Desigualdad y estrategias de supervivencia en la p.pdf}
}

