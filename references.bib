@article{bratuskinsDigitalInformationTools2020,
  title = {Digital Information Tools for Urban Regeneration: {{Capital}}'s Approach in Theory and Practice},
  shorttitle = {Digital Information Tools for Urban Regeneration},
  author = {Bratu{\v s}kins, U{\c g}is and Zaleckis, K{\k e}stutis and Treija, Sandra and Koro{\c l}ova, Alisa and Kami{\v c}aityt{\.e}, J{\=u}rat{\.e}},
  year = 2020,
  month = sep,
  journal = {Sustainability},
  volume = {12},
  number = {19},
  pages = {8082},
  issn = {2071-1050},
  doi = {10.3390/su12198082},
  urldate = {2024-03-13},
  abstract = {Urban regeneration, which includes renovation of decaying urban structures as well as renovation of dilapidated buildings, is an important economic, aesthetic and cultural factor for sustainable development planning worldwide. The revitalization of urban structures is a complex challenge, influenced by various interdisciplinary aspects, like urban socio-economic development, integrated transport and mobility solutions and others. And it requires involvement of different stakeholders at different levels in identifying and finding solutions. Technological innovations offer a variety of digital tools to address modern urban governance and modelling issues, identifying problem areas with public involvement and participation that allow relevant services to respond quickly, thus improving the urban environment and the quality of life of people. With the help of digital tools, it is also possible to promote the availability of public services, model and forecast environmental risks, as well as perform other functions integral to the organization and management of modern society. However, the wide range of these tools and their mutually asynchronous use often make it difficult to choose the right tool, thus creating the risk of fragmented implementation. The aim of this paper is to propose theoretical approach for modelling of complex interactions affecting urban regeneration as well as summarize and systematize the existing digital information tools which might empower the process of regeneration. The analysis of the use and impact of digital and smart tools allows to identify urban problems, as well as to outline ways to solve them. The results of the research will form the basis for further research stages.},
  langid = {english},
  note = {[TLDR] The aim of this paper is to propose theoretical approach for modelling of complex interactions affecting urban regeneration as well as summarize and systematize the existing digital information tools which might empower the process of regeneration.},
  file = {C:\Users\Jorge Recio\Zotero\storage\HMQ98CUC\Bratuškins et al. - 2020 - Digital Information Tools for Urban Regeneration .pdf}
}

